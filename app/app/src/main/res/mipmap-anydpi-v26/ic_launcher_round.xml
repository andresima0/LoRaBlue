<?xml version="1.0" encoding="utf-8"?>
<!--
    Round adaptive launcher icon descriptor (API 26+).
    Place this file in:  res/mipmap-anydpi-v26/ic_launcher_round.xml
    Launchers that request the "round" variant (e.g. Pixel Launcher on some
    Android versions) will use this file; the content is identical to the
    standard adaptive icon because the adaptive-icon format already handles
    shape masking automatically.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
