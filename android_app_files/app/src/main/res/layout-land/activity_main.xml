<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center_vertical"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="12dp"
            android:text="LoRaBlue IoT"
            android:textColor="#333333"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="36dp"
            android:text="Status: Disconnected"
            android:textColor="#F44336"
            android:textSize="18sp" />

        <!-- ==================================================== -->
        <!-- SIDE-BY-SIDE CARDS — landscape                        -->
        <!-- ==================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- ============== -->
            <!-- CISTERN (id=1) -->
            <!-- ============== -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Cistern"
                    android:textColor="#555555"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/cardCistern"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:clickable="true"
                    android:elevation="4dp"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvCisternWaterLevel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Water Level: -- m"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tvCisternWaterPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:text="(-- %)"
                            android:textColor="#888888"
                            android:textSize="18sp" />

                        <ImageButton
                            android:id="@+id/btnCisternDepthConfig"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:contentDescription="Configure Cistern depth"
                            android:focusable="true"
                            android:padding="6dp"
                            android:src="@drawable/ic_gear" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvCisternPump"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Water Pump: --"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/tvCisternBattery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Battery: -- %"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/tvCisternRssi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="RSSI: -- dBm"
                        android:textColor="#888888"
                        android:textSize="20sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ========== -->
            <!-- TANK (id=2) -->
            <!-- ========== -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Tank"
                    android:textColor="#555555"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/cardTank"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:clickable="true"
                    android:elevation="4dp"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvTankWaterLevel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Water Level: -- m"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tvTankWaterPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:text="(-- %)"
                            android:textColor="#888888"
                            android:textSize="18sp" />

                        <ImageButton
                            android:id="@+id/btnTankDepthConfig"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:contentDescription="Configure Tank depth"
                            android:focusable="true"
                            android:padding="6dp"
                            android:src="@drawable/ic_gear" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTankTurbidity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Turbidity: -- NTU"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/tvTankBattery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Battery: -- %"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/tvTankRssi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="RSSI: -- dBm"
                        android:textColor="#888888"
                        android:textSize="20sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- ==================================================== -->
        <!-- ACTION BUTTONS                                       -->
        <!-- ==================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_marginEnd="12dp"
                android:layout_weight="1"
                android:text="SCAN &amp; CONNECT"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnTxTest"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_weight="1"
                android:backgroundTint="#9E9E9E"
                android:text="TX TEST"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="0dp"
                android:layout_height="68dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:backgroundTint="#607D8B"
                android:text="PLATFORM SETTINGS"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>